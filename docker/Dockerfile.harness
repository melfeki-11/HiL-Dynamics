# Trust Horizon Harness Image
#
# Extends any hilbench-swe:<uid> task image with:
#   - Node.js 20 runtime
#   - All trust_horizon npm dependencies (agent SDKs + CLIs) pre-installed
#   - google-adk[extensions] Python package (ADK SDK only, via --build-arg SDK=adk)
#
# At build time:
#   docker build --build-arg BASE_IMAGE=hilbench-swe:<uid> \
#                --build-arg SDK=claude \        # or codex, or adk
#                -t hilbench-swe-harness-<sdk>:<uid> \
#                -f docker/Dockerfile.harness .
#
# At run time, bind-mount the harness source (so code changes don't need rebuilds):
#   docker run --rm --network host \
#     -v /path/to/trust_horizon/src:/opt/trust_horizon/src:ro \
#     -v /path/to/trust_horizon/scripts:/opt/trust_horizon/scripts:ro \
#     -v <output_dir>:/output \
#     -e TASK_UID=<uid> -e MODE=ask_human -e ... \
#     hilbench-swe-harness-<sdk>:<uid> \
#     node /opt/trust_horizon/src/hil_swe/run_claude.mjs

ARG BASE_IMAGE
FROM node:20-bookworm-slim AS node_runtime

ARG BASE_IMAGE
FROM ${BASE_IMAGE}

# SDK selector — propagated from build-time --build-arg SDK=<value>.
# Used to conditionally install SDK-specific Python packages.
# Supported values: claude | codex | adk
ARG SDK=claude

# ── Node.js runtime bootstrap ────────────────────────────────────────────────
# Most base images are Debian-like; some have very little writable apt cache.
# Instead of forcing apt upgrades, keep a pre-bundled Node 20 toolchain from
# node_runtime and only install via apk on Alpine/musl images.
COPY --from=node_runtime /usr/local/ /opt/node20/

# ── Node.js 20 ───────────────────────────────────────────────────────────────
# Reuse existing Node/NPM if already compatible (>=18). Otherwise:
#   - Alpine: install nodejs+npm via apk (musl-compatible runtime)
#   - Non-Alpine: copy Node 20 binaries from node_runtime stage.
RUN set -e; \
    if command -v node >/dev/null 2>&1 && command -v npm >/dev/null 2>&1; then \
        NODE_MAJOR="$(node -v | sed -E 's/^v([0-9]+).*/\1/')"; \
        if [ "${NODE_MAJOR}" -ge 18 ]; then \
            echo "Using preinstalled Node $(node -v) and npm $(npm -v)"; \
            node --version; \
            npm --version; \
            exit 0; \
        fi; \
    fi; \
    if command -v apk >/dev/null 2>&1; then \
        apk add --no-cache nodejs npm && \
        ln -sf /usr/bin/node /usr/local/bin/node && \
        ln -sf /usr/bin/npm /usr/local/bin/npm; \
    else \
        cp -a /opt/node20/. /usr/local/; \
    fi && \
    node --version && npm --version

# ── bubblewrap (Codex only) ───────────────────────────────────────────────────
# Codex CLI uses bwrap internally to sandbox shell commands.  The setuid bit
# lets bwrap create user namespaces even when kernel.unprivileged_userns_clone=0
# (the default in most Docker environments).
# Not needed for Claude or ADK — installing separately keeps failures isolated.
RUN if [ "${SDK}" = "codex" ]; then \
        if command -v apt-get >/dev/null 2>&1; then \
            apt-get update -qq && \
            apt-get install -y --no-install-recommends bubblewrap && \
            rm -rf /var/lib/apt/lists/* && \
            chmod u+s /usr/bin/bwrap; \
        elif command -v apk >/dev/null 2>&1; then \
            apk add --no-cache bubblewrap && chmod u+s /usr/bin/bwrap; \
        elif command -v dnf >/dev/null 2>&1; then \
            dnf install -y bubblewrap && chmod u+s /usr/bin/bwrap; \
        elif command -v yum >/dev/null 2>&1; then \
            yum install -y bubblewrap && chmod u+s /usr/bin/bwrap; \
        else \
            echo "WARNING: bubblewrap unavailable (no supported package manager)"; \
        fi; \
    fi

# ── OpenCode musl/glibc compatibility (OpenCode SDK only) ────────────────────
# OpenCode's bundled runtime binary is glibc-linked. On Alpine/musl task images,
# install compatibility shims so /opt/trust_horizon/node_modules/opencode-ai/bin/.opencode
# can execute instead of failing with ENOENT from missing loader/symbols.
RUN if [ "${SDK}" = "opencode" ]; then \
        if command -v apk >/dev/null 2>&1; then \
            apk add --no-cache libc6-compat gcompat; \
        fi; \
    fi

# ── Trust Horizon npm deps ────────────────────────────────────────────────────
# Copy only package manifests first for layer caching.
# Source files are bind-mounted at runtime — rebuilds are only needed when
# package.json / package-lock.json change (i.e. SDK version bumps).
WORKDIR /opt/trust_horizon
COPY package.json package-lock.json ./
RUN npm ci --omit=dev 2>&1

# Expose node_modules/.bin on PATH so harness subprocesses can call
# `codex`, `opencode`, etc. by name without full paths.
ENV PATH="/opt/trust_horizon/node_modules/.bin:${PATH}"

# ── Claude Code CLI ───────────────────────────────────────────────────────────
# The agent SDK spawns the `claude` binary as a subprocess.  Install it
# globally so it is on PATH inside the container.
# Non-fatal on Alpine (musl libc): the claude CLI ships glibc binaries only;
# harness containers on Alpine will still work via the SDK-only path.
RUN npm install -g @anthropic-ai/claude-code@2.1.139 2>&1 || \
    echo "WARNING: claude CLI install failed (musl/Alpine?); SDK-only mode will be used"

# ── Google ADK (Python) — ADK SDK only ───────────────────────────────────────
# Installed only when SDK=adk to keep claude/codex/opencode image behavior unchanged.
# Python 3 is already present in SWE-agent task images.
#
# Install strategy:
#   • Always build a dedicated ADK virtualenv at /opt/trust_horizon/.venv-adk.
#     This guarantees a stable ADK runtime (including skills APIs) without
#     mutating the task image's system python environment.
#   • Keep task python untouched so agent bash commands like "python3 -m pytest"
#     continue using the task's native language/runtime dependencies.
#   • If system python3 is <3.10, install CPython 3.11 via uv and use that only
#     for the ADK virtualenv.
#   • Pin to a skills-capable ADK version and verify imports at build time.
RUN set -e; if [ "${SDK}" = "adk" ]; then \
        ADK_BASE_PY="$(command -v python3)"; \
        if [ -z "${ADK_BASE_PY}" ]; then \
            echo "ERROR: python3 not found in base image"; \
            exit 1; \
        fi; \
        PY_MINOR=$("${ADK_BASE_PY}" -c "import sys; print(sys.version_info.minor)" 2>/dev/null || echo 0); \
        PY_MAJOR=$("${ADK_BASE_PY}" -c "import sys; print(sys.version_info.major)" 2>/dev/null || echo 0); \
        if [ "$PY_MAJOR" -eq 3 ] && [ "$PY_MINOR" -lt 10 ]; then \
            echo "ADK: system Python 3.${PY_MINOR} < 3.10 — installing Python 3.11"; \
            if command -v apt-get >/dev/null 2>&1; then \
                if apt-get update -qq && \
                   (apt-get install -y --no-install-recommends python3.11 python3.11-venv python3.11-distutils || \
                    apt-get install -y --no-install-recommends python3.11 python3.11-venv); then \
                    ADK_BASE_PY="$(command -v python3.11)"; \
                fi; \
            fi; \
            PY_MINOR_NEW=$("${ADK_BASE_PY}" -c "import sys; print(sys.version_info.minor)" 2>/dev/null || echo 0); \
            if [ "${PY_MINOR_NEW}" -lt 10 ]; then \
                "${ADK_BASE_PY}" -m pip install --no-cache-dir --break-system-packages uv 2>&1 || \
                "${ADK_BASE_PY}" -m pip install --no-cache-dir uv 2>&1; \
                UV_BIN="$(command -v uv)"; \
                "$UV_BIN" python install 3.11 2>&1; \
                ADK_BASE_PY=$("$UV_BIN" python find cpython-3.11 2>/dev/null || "$UV_BIN" python find 3.11); \
            fi; \
            echo "ADK: using python at ${ADK_BASE_PY}"; \
        fi; \
        ADK_VENV="/opt/trust_horizon/.venv-adk"; \
        if ! "${ADK_BASE_PY}" -m venv "${ADK_VENV}"; then \
            if command -v apt-get >/dev/null 2>&1; then \
                apt-get update -qq && apt-get install -y --no-install-recommends python3-venv || true; \
                "${ADK_BASE_PY}" -m venv "${ADK_VENV}" || true; \
            fi; \
            if [ ! -x "${ADK_VENV}/bin/python" ]; then \
                "${ADK_BASE_PY}" -m pip install --no-cache-dir --break-system-packages uv 2>&1 || \
                "${ADK_BASE_PY}" -m pip install --no-cache-dir uv 2>&1; \
                UV_BIN="$(command -v uv)"; \
                "$UV_BIN" venv --seed --python "${ADK_BASE_PY}" "${ADK_VENV}"; \
            fi; \
        fi; \
        "${ADK_VENV}/bin/python" -m pip install --no-cache-dir --upgrade pip setuptools wheel 2>&1; \
        "${ADK_VENV}/bin/python" -m pip install --no-cache-dir 'google-adk==1.33.0' 'litellm' 2>&1; \
        "${ADK_VENV}/bin/python" -c "from google.adk.models.lite_llm import LiteLlm; import litellm; from google.adk.skills import load_skill_from_dir; from google.adk.tools import skill_toolset"; \
        printf '#!/bin/sh\n' > /usr/local/bin/python3.adk; \
        printf 'exec %s/bin/python "$@"\n' "${ADK_VENV}" >> /usr/local/bin/python3.adk; \
        chmod +x /usr/local/bin/python3.adk; \
        echo "ADK: python3.adk wrapper -> ${ADK_VENV}/bin/python  ($(${ADK_VENV}/bin/python --version 2>&1))"; \
    fi

# ── Sanity check ─────────────────────────────────────────────────────────────
# Both claude-agent-sdk and codex-sdk are ESM-only, so use dynamic import()
# with --input-type=module rather than require().
RUN node --version && \
    node -e "var v=parseInt(process.version.slice(1));if(v<18){console.error('ERROR: Node.js >=18 required, got '+process.version);process.exit(1)}else{console.log('Node.js version ok: '+process.version)}" && \
    node --input-type=module -e "import('@anthropic-ai/claude-agent-sdk').then(()=>console.log('claude-agent-sdk ok'))" && \
    node --input-type=module -e "import('zod').then(()=>console.log('zod ok'))" && \
    (claude --version 2>/dev/null || echo 'claude cli version check skipped') && \
    (codex --version 2>/dev/null || echo 'codex cli version check skipped') && \
    (opencode --version 2>/dev/null || echo 'opencode cli version check skipped') && \
    if [ "${SDK}" = "adk" ]; then \
        python3.adk -c "from google.adk.models.lite_llm import LiteLlm; import litellm; from google.adk.skills import load_skill_from_dir; from google.adk.tools import skill_toolset; print('google-adk+skills+litellm ok  python3.adk=' + __import__('sys').version.split()[0])"; \
    fi

# SWE-agent base images set ENTRYPOINT ["sleep", "infinity"] so containers can be
# exec-ed into.  Reset it so docker run can pass a real command directly.
ENTRYPOINT []

# Default working dir is the task repo (SWE-agent images use /testbed)
WORKDIR /testbed
