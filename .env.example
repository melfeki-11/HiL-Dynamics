# HiL-Dynamics credentials — copy this file to .env and fill in real values.
# .env is gitignored; never commit it.
#
# LiteLLM proxy — the primary way to call all models.
# Set this to your LiteLLM endpoint URL.
LITELLM_BASE_URL="https://<your-litellm-endpoint>"
LITELLM_API_KEY="sk-..."

# HuggingFace token — needed to download hil-bench task Docker images.
HF_TOKEN="hf_..."

# ── Optional overrides ──────────────────────────────────────────────────────

# Default agent model slug as understood by the LiteLLM proxy.
# Examples: claude-sonnet-4-6  claude-opus-4-7  gpt-5.5  gemini-2.5-pro
# CLAUDE_MODEL="claude-sonnet-4-6"

# Override the ask_human judge endpoint/model.
# Must be set — the judge routes clarification questions against the blocker registry.
# Use any model slug your LiteLLM proxy supports (e.g. meta-llama/Llama-3.3-70B-Instruct).
# ASK_HUMAN_BASE_URL="https://<your-litellm-endpoint>/v1"
# ASK_HUMAN_MODEL="<your-judge-model>"

# Per-attempt hard timeout (milliseconds, default 3600000 = 1 h)
# ATTEMPT_TIMEOUT_MS="3600000"
