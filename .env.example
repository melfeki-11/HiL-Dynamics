# HiL-Dynamics credentials — copy this file to .env and fill in real values.
# .env is gitignored; never commit it.
#
# LiteLLM proxy — the primary way to call all models.
# Set this to your LiteLLM endpoint URL.
LITELLM_BASE_URL="https://<your-litellm-endpoint>"
LITELLM_API_KEY="sk-..."

# ── Alternative: direct provider key (no LiteLLM proxy needed) ───────────────
# Uncomment ONE of the following if you have a direct provider API key.
# Credentials resolve in priority order: LITELLM_API_KEY → ANTHROPIC_AUTH_TOKEN → OPENAI_API_KEY
# ANTHROPIC_AUTH_TOKEN="sk-ant-..."
# ANTHROPIC_BASE_URL="https://api.anthropic.com"
# OPENAI_API_KEY="sk-..."
# OPENAI_BASE_URL="https://api.openai.com/v1"

# HuggingFace token — needed to pull task Docker base images.
HF_TOKEN="hf_..."

# ── Ask-human judge ───────────────────────────────────────────────────────────
# Required for neutral and skill arms. Not needed for full_info-only runs.
# Any instruction-tuned model your LiteLLM proxy serves works.
# Paper results used: meta-llama/Llama-3.3-70B-Instruct
ASK_HUMAN_MODEL="<your-judge-model>"

# Override the judge endpoint if it differs from LITELLM_BASE_URL/v1.
# ASK_HUMAN_BASE_URL="https://<your-litellm-endpoint>/v1"

# ── Optional overrides ────────────────────────────────────────────────────────

# Default agent model slug as understood by the LiteLLM proxy.
# Examples: claude-sonnet-4-6  claude-opus-4-7  gpt-5.5  gemini-2.5-pro
# CLAUDE_MODEL="claude-sonnet-4-6"

# Override the ask_human judge endpoint/model.
# Defaults to LITELLM_BASE_URL/v1 + llmengine/llama-3-3-70b-instruct.
# ASK_HUMAN_BASE_URL="https://<your-litellm-endpoint>/v1"
# ASK_HUMAN_MODEL="llmengine/llama-3-3-70b-instruct"

# Per-attempt hard timeout (milliseconds, default 3600000 = 1 h)
# ATTEMPT_TIMEOUT_MS="3600000"
